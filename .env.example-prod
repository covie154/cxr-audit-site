# ================================
# PRIMER-LLM - Production/PostgreSQL Environment Template
# Copy to .env for a production-style deployment and replace every placeholder.
# Do not commit real secrets.
# ================================

# -- Django ---------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.example,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example,https://localhost

# -- PostgreSQL: application database ------------------------
DATABASE_ENGINE=postgres
DATABASE_NAME=primer_app
DATABASE_USER=primer_app_user
DATABASE_PASSWORD=change-me-app-db-password
DATABASE_HOST=postgres
DATABASE_PORT=5432
# Use require/verify-full for managed TLS-enabled databases. Leave blank for
# isolated local/internal-review Compose if TLS is not configured.
DATABASE_SSLMODE=
DATABASE_CONN_MAX_AGE=60
DATABASE_CONN_HEALTH_CHECKS=True

# -- PostgreSQL: audit database ------------------------------
AUDIT_DATABASE_ENGINE=postgres
AUDIT_DATABASE_NAME=primer_audit
AUDIT_DATABASE_USER=primer_audit_user
AUDIT_DATABASE_PASSWORD=change-me-audit-db-password
AUDIT_DATABASE_HOST=postgres
AUDIT_DATABASE_PORT=5432
AUDIT_DATABASE_SSLMODE=
AUDIT_DATABASE_CONN_MAX_AGE=60
AUDIT_DATABASE_CONN_HEALTH_CHECKS=True

# -- PostgreSQL container bootstrap for local/internal review -
# Production should use DBA-managed or managed-database provisioning.
POSTGRES_DB=primer_admin
POSTGRES_USER=primer_admin
POSTGRES_PASSWORD=change-me-postgres-admin-password
POSTGRES_APP_DB=primer_app
POSTGRES_APP_USER=primer_app_user
POSTGRES_APP_PASSWORD=change-me-app-db-password
POSTGRES_AUDIT_DB=primer_audit
POSTGRES_AUDIT_USER=primer_audit_user
POSTGRES_AUDIT_PASSWORD=change-me-audit-db-password

# -- Django superuser bootstrap ------------------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password
DJANGO_SUPERUSER_EMAIL=admin@example.com

# -- Gunicorn -------------------------------------------------
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# -- OpenAI-compatible LLM endpoint --------------------------
OLLAMA_BASE_URL=https://llm.example.internal/v1
OLLAMA_MODEL=qwen3:32b-q4_K_M
OLLAMA_API_KEY=change-me-llm-api-key
OLLAMA_MAX_WORKERS=8
LLM_ALLOW_INSECURE_TRANSPORT=False

# -- Email ----------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=change-me-email-password
DEFAULT_FROM_EMAIL=PRIMER-LLM <your-email@example.com>

# -- Django to FastAPI authentication ------------------------
API_SECRET_KEY=change-me-to-a-random-service-secret
API_REQUIRE_AUTH=True
FASTAPI_CORS_ORIGINS=https://your-domain.example

# -- Excel decryption ----------------------------------------
XLSX_DECRYPT_PASSWORD=change-me

# -- Nginx ports ---------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
